# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (default — no setup needed for development)
DATABASE_URL=sqlite:///./smart_resource.db

# Supabase PostgreSQL — use the POOLER connection string from:
# Supabase Dashboard → Settings → Database → Connection string → URI (Pooler)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct Supabase connection (use if pooler has issues)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-change-this

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your deployed frontend URL
FRONTEND_URL=https://smart-resource-allocation.vercel.app

# ─── Admin Seed Account ───────────────────────────────────────────────────────
# These are used by seed_prod.py to create the initial admin account.
# Change ADMIN_PASSWORD before deploying!
ADMIN_EMAIL=admin@smartalloc.org
ADMIN_PASSWORD=ChangeMe@123
ADMIN_FULL_NAME=Platform Admin
