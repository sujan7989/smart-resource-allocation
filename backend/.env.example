# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (default — no setup needed for development)
DATABASE_URL=sqlite:///./smart_resource.db

# Supabase Shared Pooler (use this on Render — port 5432)
# Get from: Supabase Dashboard → Settings → Database → Connection string → Shared Pooler
# DATABASE_URL=postgresql://postgres.pigjvjhqgublraplbavv:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase Direct Connection (use for migrations/local testing)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.pigjvjhqgublraplbavv.supabase.co:5432/postgres

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-change-this

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://smart-resource-allocation.vercel.app

# ─── Admin Seed Account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@smartalloc.org
ADMIN_PASSWORD=ChangeMe@123
ADMIN_FULL_NAME=Platform Admin

# ─── Email ────────────────────────────────────────────────────────────────────
# Set ONE of these on Render. The server sends emails to ALL users automatically.
# No per-user setup needed.

# OPTION 1 — Resend (RECOMMENDED — free, 2 minutes to set up, no credit card):
#   1. Go to https://resend.com and sign up free
#   2. Click "API Keys" → "Create API Key"
#   3. Copy the key and set it as RESEND_API_KEY on Render
#   Free tier: 3,000 emails/month
RESEND_API_KEY=re_your_api_key_here

# OPTION 2 — Gmail SMTP:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to Google Account → Security → App Passwords → create one
#   3. Use that 16-char password as SMTP_PASSWORD
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password

EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_FROM_NAME=Smart Resource Allocation
