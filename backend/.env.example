# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (default — no setup needed for development)
DATABASE_URL=sqlite:///./smart_resource.db

# Supabase Shared Pooler (use this on Render — port 5432)
# Get from: Supabase Dashboard → Settings → Database → Connection string → Shared Pooler
# DATABASE_URL=postgresql://postgres.pigjvjhqgublraplbavv:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase Direct Connection (use for migrations/local testing)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.pigjvjhqgublraplbavv.supabase.co:5432/postgres

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-change-this

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://smart-resource-allocation.vercel.app

# ─── Admin Seed Account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@smartalloc.org
ADMIN_PASSWORD=ChangeMe@123
ADMIN_FULL_NAME=Platform Admin
