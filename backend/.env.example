# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (default — no setup needed for development)
DATABASE_URL=sqlite:///./smart_resource.db

# Production PostgreSQL (set this on Render)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-change-this

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (set on Render after Vercel deploy)
FRONTEND_URL=https://your-app.vercel.app

# ─── Admin Seed Account ───────────────────────────────────────────────────────
# These are used by seed_prod.py to create the initial admin account.
# Change these before deploying to production!
ADMIN_EMAIL=admin@yourorg.org
ADMIN_PASSWORD=ChangeMe@123
ADMIN_FULL_NAME=Platform Admin
